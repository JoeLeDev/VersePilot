OPENAI_API_KEY=sk-...
PORT=4000

# Fichier dans data/bibles/{slug}.json (un JSON par version, sans mélange)
BIBLE_VERSION=louis-segond

# Recherche versets: offline | hybrid | ai
SEARCH_MODE=offline

# Recherche sémantique : openai (cloud) | local (hors-ligne, sans OpenAI) | off
SEMANTIC_SEARCH=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OpenAI : npm run build-embeddings
# Local  : 1) npm run embed-server  2) npm run build-embeddings:local  3) SEMANTIC_SEARCH=local
LOCAL_EMBED_URL=http://127.0.0.1:8003
LOCAL_EMBED_MODEL=intfloat/multilingual-e5-small

# Lexique biblique STT (correction noms/lieux avant recherche)
# npm run build-lexicon  → data/biblical-lexicon.json (seed + variantes phonétiques)

# Transcription
# deepgram = cloud Nova-3 (recommandé latence + qualité FR, clé API requise)
# mlx = local Apple Silicon — npm run mlx-stt
# hybrid = deepgram puis mlx puis openai puis whisper.cpp
# local = whisper.cpp seul
STT_MODE=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=fr
# Streaming temps réel via /stt/stream (activé côté app si une clé Deepgram existe).
# Boost mots-clés bibliques : laisser false en fr/nova-3 (rejeté par Deepgram, erreur 400).
DEEPGRAM_KEYWORDS_ENABLED=false
MLX_STT_URL=http://127.0.0.1:8002
# Même modèle que Pewbeam (Apple Silicon, ~50–200 ms/segment)
MLX_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
MLX_STT_LANG=fr
# true = prompt livres bibliques (anglais) — peut provoquer des boucles en français
MLX_STT_BIBLICAL_HINTS=false
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Laisser false : le prompt est répété par le modèle sur silence / courts extraits
OPENAI_TRANSCRIBE_USE_PROMPT=false
# OPENAI_TRANSCRIBE_PROMPT=optionnel si USE_PROMPT=true

# Whisper local (si STT_MODE=local ou fallback hybrid)
WHISPER_MODE=local
WHISPER_BIN=whisper-cli
WHISPER_MODEL_PATH=./models/ggml-small.bin
WHISPER_LANG=fr
WHISPER_BEAM_SIZE=2
WHISPER_THREADS=6
WHISPER_SUPPRESS_NST=true
WHISPER_CARRY_PROMPT=false
WHISPER_USE_VAD=false
WHISPER_NO_GPU=true
WHISPER_PROMPT_MAX_CHARS=350
