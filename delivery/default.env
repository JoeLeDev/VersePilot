# VersePilot Live — configuration par défaut (copiée au premier lancement)
# macOS   : ~/Library/Application Support/versepilot-live-desktop/.env
# Windows : %APPDATA%/versepilot-live-desktop/.env

PORT=4000

SEARCH_MODE=offline
# openai | local (hors-ligne) | off
SEMANTIC_SEARCH=local
BIBLE_VERSION=louis-segond

STT_MODE=deepgram

# Mode abonnement (recommandé en production)
# VERSEPILOT_LICENSE_KEY=
# VERSEPILOT_PROXY_URL=

# Mode direct (test / 1er client)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=fr
DEEPGRAM_KEYWORDS_ENABLED=false

WHISPER_MODE=local
WHISPER_BIN=whisper-cli
WHISPER_MODEL_PATH=./models/ggml-small.bin
WHISPER_LANG=fr
WHISPER_BEAM_SIZE=2
WHISPER_THREADS=4
WHISPER_SUPPRESS_NST=true
WHISPER_CARRY_PROMPT=false
WHISPER_USE_VAD=false
WHISPER_NO_GPU=true

MLX_STT_URL=http://127.0.0.1:8002
MLX_STT_BIBLICAL_HINTS=false
