# VersePilot Live — configuration livraison client (abonnement STT inclus)
# Copié au premier lancement vers :
#   macOS   : ~/Library/Application Support/versepilot-live-desktop/.env
#   Windows : %APPDATA%/versepilot-live-desktop/.env
#
# ── À PERSONNALISER AVANT LIVRAISON ─────────────────────────────────────────
# Remplacer VERSEPILOT_LICENSE_KEY par la clé fournie pour cette église.
# VERSEPILOT_PROXY_URL = URL de votre serveur proxy (voir services/license-proxy/)

PORT=4000

# Recherche de versets : locale, sans OpenAI
SEARCH_MODE=offline
SEMANTIC_SEARCH=off
BIBLE_VERSION=louis-segond

# Dictée vocale temps réel (incluse dans l'abonnement)
STT_MODE=deepgram

# ── Mode abonnement (recommandé) — clé par église, pas de Deepgram exposé
VERSEPILOT_LICENSE_KEY=VP-REMPLACER-PAR-CLE-CLIENT
VERSEPILOT_PROXY_URL=https://api.versepilot.votredomaine.fr
DEEPGRAM_API_KEY=

# ── Mode direct (1er client / test uniquement) — décommenter et vider la licence
# DEEPGRAM_API_KEY=votre_cle_deepgram
# VERSEPILOT_LICENSE_KEY=
# VERSEPILOT_PROXY_URL=

DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=fr
DEEPGRAM_KEYWORDS_ENABLED=false

# OpenAI — non requis
OPENAI_API_KEY=

# Whisper local — secours si proxy indisponible (hybrid uniquement)
WHISPER_MODE=local
WHISPER_BIN=whisper-cli
WHISPER_MODEL_PATH=./models/ggml-small.bin
WHISPER_LANG=fr
WHISPER_BEAM_SIZE=2
WHISPER_THREADS=4
WHISPER_SUPPRESS_NST=true
WHISPER_CARRY_PROMPT=false
WHISPER_USE_VAD=false
WHISPER_NO_GPU=true

MLX_STT_URL=http://127.0.0.1:8002
MLX_STT_BIBLICAL_HINTS=false
