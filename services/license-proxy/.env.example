PORT=4100

# Clé Deepgram maître (jamais distribuée aux clients)
DEEPGRAM_API_KEY=

DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=fr
DEEPGRAM_KEYWORDS_ENABLED=false

# Fichier des licences églises (voir licenses.example.json)
LICENSES_FILE=./licenses.json

# Origines autorisées (CORS) — optionnel, * par défaut en dev
# CORS_ORIGIN=https://versepilot.example.com
