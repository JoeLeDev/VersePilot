{
  "name": "versepilot-live-desktop",
  "version": "1.1.0",
  "private": true,
  "description": "VersePilot Live desktop app (Electron + React + Node backend)",
  "engines": {
    "node": ">=18"
  },
  "main": "electron/main.js",
  "scripts": {
    "bootstrap": "node scripts/setup.mjs",
    "bootstrap:full": "node scripts/setup.mjs --with-bibles",
    "setup": "npm install --prefix backend && npm install --prefix frontend",
    "electron:fix": "node node_modules/electron/install.js",
    "reinstall": "npm run setup",
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:with-mlx": "concurrently -k \"npm run mlx-stt --prefix backend\" \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "mlx-stt": "npm run mlx-stt --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:electron": "wait-on tcp:4000 tcp:5173 && electron .",
    "import-bibles": "npm run import-bibles --prefix backend --",
    "fix-book-names": "npm run fix-book-names --prefix backend --",
    "build-embeddings": "npm run build-embeddings --prefix backend --",
    "build:frontend": "npm run build --prefix frontend",
    "release": "node scripts/release.mjs",
    "release:mac": "node scripts/release.mjs --mac",
    "release:win": "node scripts/release.mjs --win",
    "release:dir": "node scripts/release.mjs --dir",
    "license-proxy": "npm start --prefix services/license-proxy",
    "test": "npm test --prefix backend && npm test --prefix frontend",
    "dist": "npm run release:dir",
    "dist:mac": "npm run release:mac",
    "dist:win": "npm run release:win"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.versepilot.live",
    "productName": "VersePilot Live",
    "asar": true,
    "asarUnpack": [
      "backend/**/*"
    ],
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/.env",
          "!**/.env.*",
          "!**/models/**"
        ]
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "extraResources": [
      {
        "from": "delivery/default.env",
        "to": "config/default.env"
      },
      {
        "from": "delivery/docs",
        "to": "docs"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "identity": null,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
